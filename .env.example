# LLM-NetAuto-SDN Configuration
# Copy this file to .env and modify as needed

# ==============================================
# Mode Configuration
# ==============================================
# Set to true for demo mode (no external services required)
# Set to false for live mode with real ONOS, Ollama, etc.
DEMO_MODE=true

# ==============================================
# ONOS SDN Controller
# ==============================================
ONOS_HOST=127.0.0.1
ONOS_PORT=8181
ONOS_USER=onos
ONOS_PASSWORD=rocks
ONOS_APP_ID=org.onosproject.cli
ONOS_OF_PORT=6653

# ==============================================
# Ollama LLM Runtime
# ==============================================
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# ==============================================
# ChromaDB Vector Database
# ==============================================
CHROMADB_HOST=127.0.0.1
CHROMADB_PORT=8001
CHROMADB_PERSIST_PATH=./data/chromadb

# ==============================================
# FastAPI Backend
# ==============================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_WORKERS=1
FASTAPI_RELOAD=true

# ==============================================
# Streamlit Frontend
# ==============================================
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# ==============================================
# Monitoring Configuration
# ==============================================
TELEMETRY_POLL_INTERVAL=5
REMEDIATION_COOLDOWN=30
ANOMALY_CONTAMINATION=0.05
ANOMALY_THRESHOLD=-0.5

# ==============================================
# Prometheus & Grafana
# ==============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
METRICS_EXPORTER_PORT=9091

# ==============================================
# Simulation Settings (DEMO_MODE=true)
# ==============================================
SIM_LLM_MIN_DELAY_MS=800
SIM_LLM_MAX_DELAY_MS=2500
SIM_TRAFFIC_BASE_MBPS=5
SIM_ANOMALY_MULTIPLIER=10

# ==============================================
# Logging
# ==============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# ==============================================
# Security
# ==============================================
API_KEY=your-secret-api-key-here
CORS_ORIGINS=*
